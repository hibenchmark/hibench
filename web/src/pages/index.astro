---
import Layout from "../layouts/Layout.astro";
import AgentTokenRanking from "../components/AgentTokenRanking.astro";
import AgentLogo from "../components/AgentLogo.astro";
import { withBase, formatNumber } from "../lib/format";
import { getAgents } from "../data/benchmark";

const agents = getAgents();
---

<Layout>
  <!-- Hero -->
  <section class="pb-8 pt-0 text-center sm:pb-10 sm:pt-2 sm:text-left">
    <h1 class="mx-auto max-w-5xl text-balance text-4xl font-bold tracking-tight ui-heading sm:mx-0 sm:text-6xl">
      Know what your agent loads before it writes.
    </h1>
    <p class="mx-auto mt-5 max-w-3xl text-lg leading-8 ui-muted sm:mx-0 sm:max-w-5xl">
      hibench measures the default context footprint of coding agents: system
      prompts, tools, skills, MCP servers, and sub-agents loaded before the
      first user request is answered.
    </p>
    <div class="mx-auto mt-8 grid w-full max-w-md grid-cols-1 gap-3 min-[380px]:grid-cols-2 sm:mx-0 sm:flex sm:max-w-none sm:flex-wrap">
      <a
        href={withBase("/rankings")}
        class="btn-primary rounded-lg px-5 py-2.5 text-center font-bold"
      >
        View the rankings
      </a>
      <a
        href={withBase("/agents")}
        class="btn-secondary rounded-lg px-5 py-2.5 text-center font-semibold"
      >
        Explore agents
      </a>
    </div>
  </section>

  <!-- Token ranking -->
  <section class="pb-10 sm:pb-12">
    <AgentTokenRanking agents={agents} />
  </section>

  <!-- Philosophy -->
  <section class="mt-16">
    <h2 class="text-2xl font-semibold tracking-tight ui-title">
      Goal &amp; philosophy
    </h2>
    <div class="mt-6 grid gap-6 md:grid-cols-3">
      <article
        class="ui-card ui-card-hover rounded-xl p-6"
      >
        <div
          class="ui-badge mb-3 grid h-9 w-9 place-items-center rounded-lg"
        >
          ①
        </div>
        <h3 class="font-semibold ui-title">
          Default cost is real cost
        </h3>
        <p class="mt-2 text-sm ui-muted">
          Every tool schema, skill description and system instruction is sent on
          the very first turn. That baseline is paid on each request, before any
          useful work happens.
        </p>
      </article>
      <article
        class="ui-card ui-card-hover rounded-xl p-6"
      >
        <div
          class="ui-badge-warm mb-3 grid h-9 w-9 place-items-center rounded-lg"
        >
          ②
        </div>
        <h3 class="font-semibold ui-title">
          Measure, don't guess
        </h3>
        <p class="mt-2 text-sm ui-muted">
          We capture the first real outbound request and count it with a single
          fixed tokenizer so numbers stay comparable across agents, versions and
          models.
        </p>
      </article>
      <article
        class="ui-card ui-card-hover rounded-xl p-6"
      >
        <div
          class="mb-3 grid h-9 w-9 place-items-center rounded-lg text-[#ffd4df]"
          style="background:rgba(255,92,138,0.12);box-shadow:inset 0 0 0 1px rgba(255,92,138,0.24)"
        >
          ③
        </div>
        <h3 class="font-semibold ui-title">
          Track the evolution
        </h3>
        <p class="mt-2 text-sm ui-muted">
          Footprints drift over releases. hibench keeps one canonical capture
          per version so you can watch context grow (or shrink) over time.
        </p>
      </article>
    </div>
  </section>

  <!-- Methodology -->
  <section
    class="ui-card mt-16 rounded-2xl p-8"
  >
    <h2 class="text-2xl font-semibold tracking-tight ui-title">
      How it works
    </h2>
    <ol class="mt-6 grid gap-6 text-sm sm:grid-cols-2 lg:grid-cols-4">
      <li class="relative pl-9">
        <span
          class="brand-mark absolute left-0 top-0 grid h-6 w-6 place-items-center rounded-full text-xs font-bold"
          >1</span
        >
        <p class="font-semibold ui-title">Isolate</p>
        <p class="mt-1 ui-muted">
          Run each agent in Docker inside a fresh, empty Git repo.
        </p>
      </li>
      <li class="relative pl-9">
        <span
          class="brand-mark absolute left-0 top-0 grid h-6 w-6 place-items-center rounded-full text-xs font-bold"
          >2</span
        >
        <p class="font-semibold ui-title">Intercept</p>
        <p class="mt-1 ui-muted">
          Point it at a local recorder with a dummy key &mdash; no upstream
          model call.
        </p>
      </li>
      <li class="relative pl-9">
        <span
          class="brand-mark absolute left-0 top-0 grid h-6 w-6 place-items-center rounded-full text-xs font-bold"
          >3</span
        >
        <p class="font-semibold ui-title">Capture</p>
        <p class="mt-1 ui-muted">
          Send the prompt <code
            class="ui-code rounded px-1">Hi</code
          > and record the first outbound request body.
        </p>
      </li>
      <li class="relative pl-9">
        <span
          class="brand-mark absolute left-0 top-0 grid h-6 w-6 place-items-center rounded-full text-xs font-bold"
          >4</span
        >
        <p class="font-semibold ui-title">Count</p>
        <p class="mt-1 ui-muted">
          Tokenize every field with <code
            class="ui-code rounded px-1">o200k_base</code
          > and break it down.
        </p>
      </li>
    </ol>
  </section>

  <!-- Agent shortcuts -->
  <section class="mt-16">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl font-semibold tracking-tight ui-title">
        Benchmarked agents
      </h2>
      <a
        href={withBase("/agents")}
        class="text-sm font-medium ui-link"
        >All agents →</a
      >
    </div>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        agents.map((a) => {
          return (
            <a
              href={withBase(`/agents/${a.agentId}`)}
              class="ui-card ui-card-hover group rounded-xl p-6"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="flex min-w-0 items-center gap-3">
                  <AgentLogo logo={a.agentLogo} name={a.agentDisplayName} size="md" />
                  <h3 class="truncate font-semibold ui-title group-hover:text-[#9affea]">
                    {a.agentDisplayName}
                  </h3>
                </div>
                <span class="shrink-0 text-xs ui-subtle">v{a.latest.version}</span>
              </div>
              <p class="mt-3 text-3xl font-semibold tabular-nums ui-title">
                {formatNumber(a.latest.totalTokens)}
              </p>
              <p class="text-xs ui-subtle">
                default tokens · {a.latest.toolCount} tools · {a.versionCount}{" "}
                versions
              </p>
            </a>
          );
        })
      }
    </div>
  </section>
</Layout>
