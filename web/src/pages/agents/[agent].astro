---
import Layout from '../../layouts/Layout.astro';
import AgentLogo from '../../components/AgentLogo.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import StatCard from '../../components/StatCard.astro';
import EvolutionChart from '../../components/EvolutionChart.astro';
import TokenizerSwitch from '../../components/TokenizerSwitch.astro';
import VersionExplorer from '../../components/VersionExplorer.astro';
import { withBase, formatCompact, formatInputCost, formatNumber } from '../../lib/format';
import { agentPageSeo, resolveSiteUrl } from '../../lib/seo';
import { buildVersionDatum, getAgents, getAgentVersions } from '../../data/benchmark';

export async function getStaticPaths() {
  return getAgents().map((a) => ({ params: { agent: a.agentId } }));
}

const { agent } = Astro.params;
const summary = getAgents().find((a) => a.agentId === agent)!;
const versions = getAgentVersions(agent!);
const latest = summary.latest;
const first = versions[0];
const previous = versions[versions.length - 2] ?? first;
const agentName = summary.agentDisplayName;
const links = summary.agentLinks;
const hasAnthropicData = versions.length > 0 && versions.every((run) => run.anthropicTotalTokens > 0);
const anthropicModel = latest.anthropicTokenizerModel || 'claude-opus-4-8';

// Footprint rank heaviest-first across all agents (getAgents() is already
// sorted by descending latest totalTokens).
const allAgents = getAgents();
const rank = allAgents.findIndex((a) => a.agentId === agent) + 1;
const allAgentsAnthropic = [...allAgents].sort(
  (a, b) => b.latest.anthropicTotalTokens - a.latest.anthropicTotalTokens,
);
const anthropicRank = allAgentsAnthropic.findIndex((a) => a.agentId === agent) + 1 || rank;
const { title, description, ogImage, ogImageAlt, jsonLd } = agentPageSeo(
  resolveSiteUrl(Astro.site),
  summary,
);

const delta = latest.totalTokens - previous.totalTokens;
const deltaPct = previous.totalTokens ? (delta / previous.totalTokens) * 100 : 0;
const latestAnthropicTokens = latest.anthropicTotalTokens || latest.totalTokens;
const previousAnthropicTokens = previous.anthropicTotalTokens || previous.totalTokens;
const deltaAnthropic = latestAnthropicTokens - previousAnthropicTokens;
const deltaAnthropicPct = previousAnthropicTokens ? (deltaAnthropic / previousAnthropicTokens) * 100 : 0;
const initialRank = rank;
const initialTokens = latest.totalTokens;
const initialDelta = delta;
const initialDeltaPct = deltaPct;

const summaries = versions.map((run) => ({
  version: run.version,
  model: run.model,
  totalTokens: run.totalTokens,
  anthropicTotalTokens: run.anthropicTotalTokens || run.totalTokens,
  bodyBytes: run.bodyBytes,
  toolCount: run.toolCount,
  skillCount: run.skillCount,
  subagentCount: run.subagentCount,
}));

const latestRun = versions[versions.length - 1];
const initialDetail = latestRun ? buildVersionDatum(latestRun) : null;
---

<Layout title={title} description={description} ogImage={ogImage} ogImageAlt={ogImageAlt} jsonLd={jsonLd}>
  <nav class="mb-6 text-sm ui-subtle">
    <a href={withBase('/agents')} class="ui-link">Agents</a>
    <span class="mx-1.5">/</span>
    <span class="ui-muted">{agentName}</span>
  </nav>

  <header class="mb-10">
    <div class="flex items-center gap-4">
      <AgentLogo logo={summary.agentLogo} name={agentName} size="lg" />
      <div class="min-w-0">
        <h1 class="truncate text-3xl font-bold tracking-tight ui-heading">{agentName}</h1>
        <p class="mt-2 ui-muted">
          Latest <span class="font-medium">v{latest.version}</span>
        </p>
        <LastUpdated date={latest.startedAt} class="mt-2" />
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <a
            href={withBase('/rankings')}
            class="ui-badge rounded-full px-2.5 py-1 text-xs font-semibold tabular-nums"
            title="View full rankings"
            data-tokenizer-text
            data-o200k-text={`Rank #${rank} of ${allAgents.length}`}
            data-anthropic-text={`Rank #${anthropicRank} of ${allAgents.length}`}
          >
            Rank #{initialRank} of {allAgents.length}
          </a>
          {
            links.officialUrl && (
              <a
                href={links.officialUrl}
                class="official-link group inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg
                  class="official-link-icon"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <circle cx="12" cy="12" r="9" />
                  <path d="M3 12h18" />
                  <path d="M12 3a14 14 0 0 1 0 18a14 14 0 0 1 0-18" />
                </svg>
                <span>Official site</span>
              </a>
            )
          }
          {
            links.githubUrl && links.githubStars ? (
              <a
                href={links.githubUrl}
                class="github-link group inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold tabular-nums"
                title={`${formatNumber(links.githubStars)} GitHub stars on ${links.githubRepo}${
                  links.githubStarsUpdatedAt ? ` (updated ${links.githubStarsUpdatedAt})` : ''
                }`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <span class="github-link-icon" aria-hidden="true" />
                <span>GitHub</span>
                <span class="github-link-stars">★ {formatCompact(links.githubStars)}</span>
              </a>
            ) : null
          }
        </div>
      </div>
    </div>
  </header>

  <div class="mb-5">
    <TokenizerSwitch hasAnthropicData={hasAnthropicData} anthropicModel={anthropicModel} />
  </div>

  <!-- Latest snapshot -->
  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
    <div class="ui-card rounded-xl p-5">
      <p class="text-sm font-medium ui-muted">Default tokens</p>
      <p
        class="mt-1 text-3xl font-semibold tracking-tight ui-title tabular-nums"
        data-tokenizer-value
        data-o200k-value={String(latest.totalTokens)}
        data-anthropic-value={String(latestAnthropicTokens)}
      >
        {formatNumber(initialTokens)}
      </p>
      <p
        class="mt-1 text-xs ui-subtle"
        data-tokenizer-text
        data-o200k-text="o200k_base · latest request"
        data-anthropic-text={`${anthropicModel} · total-only`}
      >
        o200k_base · latest request
      </p>
    </div>
    <StatCard label="Tools" value={String(latest.toolCount)} hint="tool definitions" />
    <StatCard label="Skills" value={String(latest.skillCount)} hint="skill entries" />
    <StatCard label="Sub-agents" value={String(latest.subagentCount)} hint="sub-agent declarations" />
    <div class="ui-card rounded-xl p-5">
      <p class="text-sm font-medium ui-muted">Normalized input-cost index</p>
      <p
        class="mt-1 text-3xl font-semibold tracking-tight ui-title tabular-nums"
        data-tokenizer-value
        data-tokenizer-format="input-cost"
        data-o200k-value={String(latest.totalTokens)}
        data-anthropic-value={String(latestAnthropicTokens)}
      >
        {formatInputCost(initialTokens)}
      </p>
      <p class="mt-1 text-xs ui-subtle">
        At a common comparison rate of $5 per million input tokens. Not an
        estimate of actual agent billing.
      </p>
    </div>
    <div class="ui-card rounded-xl p-5">
      <p class="text-sm font-medium ui-muted">Since v{previous.version}</p>
      <p
        class="mt-1 text-3xl font-semibold tracking-tight ui-title tabular-nums"
        data-tokenizer-value
        data-tokenizer-format="signed"
        data-o200k-value={String(delta)}
        data-anthropic-value={String(deltaAnthropic)}
      >
        {`${initialDelta >= 0 ? '+' : ''}${formatNumber(initialDelta)}`}
      </p>
      <p
        class="mt-1 text-xs ui-subtle"
        data-tokenizer-text
        data-o200k-text={`${deltaPct >= 0 ? '+' : ''}${deltaPct.toFixed(0)}% total tokens`}
        data-anthropic-text={`${deltaAnthropicPct >= 0 ? '+' : ''}${deltaAnthropicPct.toFixed(0)}% total tokens`}
      >
        {`${initialDeltaPct >= 0 ? '+' : ''}${initialDeltaPct.toFixed(0)}% total tokens`}
      </p>
    </div>
  </section>

  <!-- Evolution -->
  <section class="mt-10">
    <div class="ui-card rounded-2xl p-6">
      <div class="mb-4 flex flex-wrap items-start justify-between gap-4">
        <div>
          <h2 class="mb-1 text-lg font-semibold ui-title">Footprint by version</h2>
          <p class="text-sm ui-subtle">
            Total request tokens and tool counts across every captured release.
          </p>
        </div>
        <div class="flex items-center gap-5 text-sm ui-subtle" aria-label="Chart legend">
          <span class="inline-flex items-center gap-2">
            <span class="h-1 w-8 rounded-full" style="background: var(--color-primary);"></span>
            <span>Tokens</span>
          </span>
          <span class="inline-flex items-center gap-2">
            <span class="w-8 border-t-[3px] border-dashed" style="border-color: var(--color-secondary);"></span>
            <span>Tools</span>
          </span>
        </div>
      </div>
      <div data-tokenizer-panel="o200k">
        <EvolutionChart runs={versions} tokenMetric="o200k" />
      </div>
      <div data-tokenizer-panel="anthropic" hidden={hasAnthropicData}>
        <EvolutionChart runs={versions} tokenMetric="anthropic" />
      </div>
    </div>
  </section>

  <!-- Interactive explorer -->
  <section class="mt-12">
    <h2 class="mb-1 text-2xl font-semibold tracking-tight ui-title">Version explorer</h2>
    <p class="mb-6 ui-muted">
      Select any version to inspect its footprint composition and the token
      footprint of each tool, skill, and sub-agent declaration.
      <span data-tokenizer-panel="anthropic" hidden>
        Anthropic mode updates total request tokens only; breakdowns remain o200k_base.
      </span>
    </p>
    {
      initialDetail ? (
        <VersionExplorer agentId={agent!} summaries={summaries} initialDetail={initialDetail} />
      ) : (
        <div class="ui-card rounded-xl p-5">
          <p class="text-sm ui-subtle">No benchmark versions available.</p>
        </div>
      )
    }
  </section>
</Layout>

<style>
  .official-link {
    color: var(--color-secondary);
    background: rgba(255, 184, 107, 0.12);
    border: 1px solid rgba(255, 184, 107, 0.22);
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      transform 0.15s ease;
  }

  .official-link:hover {
    background: rgba(255, 184, 107, 0.2);
    border-color: rgba(255, 184, 107, 0.4);
    transform: translateY(-1px);
  }

  .official-link-icon {
    width: 0.95rem;
    height: 0.95rem;
  }

  .official-link-arrow {
    padding-left: 0.4rem;
    margin-left: 0.1rem;
    border-left: 1px solid rgba(255, 184, 107, 0.3);
  }

  .github-link {
    color: var(--color-secondary);
    background: rgba(255, 184, 107, 0.12);
    border: 1px solid rgba(255, 184, 107, 0.22);
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      transform 0.15s ease;
  }

  .github-link:hover {
    background: rgba(255, 184, 107, 0.2);
    border-color: rgba(255, 184, 107, 0.4);
    transform: translateY(-1px);
  }

  .github-link-icon {
    width: 0.95rem;
    height: 0.95rem;
    background-color: currentColor;
    -webkit-mask: url('/github-svgrepo-com.svg') center / contain no-repeat;
    mask: url('/github-svgrepo-com.svg') center / contain no-repeat;
  }

  .github-link-stars {
    padding-left: 0.4rem;
    margin-left: 0.1rem;
    border-left: 1px solid rgba(255, 184, 107, 0.3);
  }
</style>
