---
import Layout from '../../layouts/Layout.astro';
import AgentLogo from '../../components/AgentLogo.astro';
import { withBase, formatNumber } from '../../lib/format';
import { getAgents } from '../../data/benchmark';

const agents = getAgents();
---

<Layout title="Agents — hibench">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight ui-heading">Agents</h1>
    <p class="mt-3 max-w-2xl ui-muted">
      Pick an agent to explore its footprint composition, per-version detail and
      how its default context has evolved over releases.
    </p>
  </header>

  <div class="grid min-w-0 grid-cols-1 gap-5 sm:grid-cols-2">
    {agents.map((a) => {
      return (
        <a
          href={withBase(`/agents/${a.agentId}`)}
          class="ui-card ui-card-hover group flex min-w-0 max-w-full flex-col overflow-hidden rounded-2xl p-5 sm:p-6"
        >
          <div class="flex min-w-0 items-start justify-between gap-4">
            <div class="flex min-w-0 items-center gap-3">
              <AgentLogo logo={a.agentLogo} name={a.agentDisplayName} size="md" />
              <div class="min-w-0">
                <h2 class="truncate text-lg font-semibold ui-title group-hover:text-[#9affea]">
                  {a.agentDisplayName}
                </h2>
                <p class="truncate text-sm ui-subtle">
                  latest v{a.latest.version} · {a.latest.model}
                </p>
              </div>
            </div>
            <span class="ui-badge shrink-0 rounded-full px-2.5 py-1 text-xs font-medium">
              {a.versionCount} versions
            </span>
          </div>

          <div class="mt-6 grid min-w-0 grid-cols-3 gap-3 sm:gap-4">
            <div>
              <p class="text-2xl font-semibold tabular-nums ui-title">{formatNumber(a.latest.totalTokens)}</p>
              <p class="text-xs ui-subtle">total tokens</p>
            </div>
            <div>
              <p class="text-2xl font-semibold tabular-nums ui-title">{a.latest.toolCount}</p>
              <p class="text-xs ui-subtle">tools</p>
            </div>
            <div>
              <p class="text-2xl font-semibold tabular-nums ui-title">{a.latest.skillCount}</p>
              <p class="text-xs ui-subtle">skills</p>
            </div>
          </div>

          <p class="mt-6 text-sm font-medium ui-link">
            Explore details →
          </p>
        </a>
      );
    })}
  </div>
</Layout>
