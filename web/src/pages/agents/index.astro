---
import Layout from '../../layouts/Layout.astro';
import AgentLogo from '../../components/AgentLogo.astro';
import TokenizerSwitch from '../../components/TokenizerSwitch.astro';
import { withBase, formatNumber } from '../../lib/format';
import { getAgents } from '../../data/benchmark';

const agents = getAgents();
const hasAnthropicData = agents.length > 0 && agents.every((a) => a.latest.anthropicTotalTokens > 0);
const anthropicModel = agents.find((a) => a.latest.anthropicTokenizerModel)?.latest.anthropicTokenizerModel ?? 'claude-opus-4-8';
const anthropicRankByAgentId = new Map(
  [...agents]
    .sort((a, b) => b.latest.anthropicTotalTokens - a.latest.anthropicTotalTokens)
    .map((agent, index) => [agent.agentId, index + 1]),
);
---

<Layout title="Agents — hibench">
  <header class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight ui-heading">Agents</h1>
    <p class="mt-3 max-w-2xl ui-muted">
      Pick an agent to explore its footprint composition, per-version detail and
      how its default context has evolved over releases.
    </p>
    <div class="mt-5">
      <TokenizerSwitch hasAnthropicData={hasAnthropicData} anthropicModel={anthropicModel} />
    </div>
  </header>

  <div class="grid min-w-0 grid-cols-1 gap-5 sm:grid-cols-2" data-tokenizer-sort-container>
    {agents.map((a, index) => {
      const rank = index + 1;
      const anthropicRank = anthropicRankByAgentId.get(a.agentId) ?? rank;
      const anthropicTokens = a.latest.anthropicTotalTokens || a.latest.totalTokens;
      return (
        <a
          href={withBase(`/agents/${a.agentId}`)}
          class="ui-card ui-card-hover group flex min-w-0 max-w-full flex-col overflow-hidden rounded-2xl p-5 sm:p-6"
          data-tokenizer-sort-item
          data-o200k-sort={String(a.latest.totalTokens)}
          data-anthropic-sort={String(anthropicTokens)}
        >
          <div class="flex min-w-0 items-start justify-between gap-4">
            <div class="flex min-w-0 items-center gap-3">
              <AgentLogo logo={a.agentLogo} name={a.agentDisplayName} size="md" />
              <div class="min-w-0">
                <h2 class="truncate text-lg font-semibold ui-title group-hover:text-[#9affea]">
                  {a.agentDisplayName}
                </h2>
                <p class="truncate text-sm ui-subtle">
                  latest v{a.latest.version} · {a.latest.model}
                </p>
              </div>
            </div>
            <div class="flex shrink-0 flex-col items-end gap-1.5">
              <span
                class="ui-badge rounded-full px-2.5 py-1 text-xs font-semibold tabular-nums"
                title={`#${rank} of ${agents.length} agents by default request tokens`}
                data-tokenizer-rank
                data-o200k-rank={String(rank)}
                data-anthropic-rank={String(anthropicRank)}
              >
                Rank #{rank}
              </span>
              <span class="text-[0.68rem] ui-subtle tabular-nums">
                {a.versionCount} versions
              </span>
            </div>
          </div>

          <div class="mt-6 grid min-w-0 grid-cols-2 gap-3 sm:grid-cols-4 sm:gap-4">
            <div>
              <p
                class="text-2xl font-semibold tabular-nums ui-title"
                data-tokenizer-value
                data-o200k-value={String(a.latest.totalTokens)}
                data-anthropic-value={String(anthropicTokens)}
              >
                {formatNumber(a.latest.totalTokens)}
              </p>
              <p class="text-xs ui-subtle">total tokens</p>
            </div>
            <div>
              <p class="text-2xl font-semibold tabular-nums ui-title">{a.latest.toolCount}</p>
              <p class="text-xs ui-subtle">tools</p>
            </div>
            <div>
              <p class="text-2xl font-semibold tabular-nums ui-title">{a.latest.skillCount}</p>
              <p class="text-xs ui-subtle">skills</p>
            </div>
            <div>
              <p class="text-2xl font-semibold tabular-nums ui-title">{a.latest.subagentCount}</p>
              <p class="text-xs ui-subtle">sub-agents</p>
            </div>
          </div>

          <p class="mt-6 text-sm font-medium ui-link">
            Explore details →
          </p>
        </a>
      );
    })}
  </div>
</Layout>
