---
import { withBase } from "../lib/format";

const path = Astro.url.pathname.replace(/\/$/, "");
const links = [
  { href: "/rankings", label: "Rankings" },
  { href: "/agents", label: "Agents" },
];

function isActive(href: string): boolean {
  const target = withBase(href).replace(/\/$/, "");
  if (target === withBase("/").replace(/\/$/, "")) return path === target;
  return path === target || path.startsWith(`${target}/`);
}
---

<header class="glass-nav sticky top-0 z-30">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-3 py-3 sm:px-4">
    <a
      href={withBase("/")}
      class="flex shrink-0 items-center gap-2 font-semibold tracking-tight"
    >
      <span
        class="brand-mark grid h-7 w-7 place-items-center rounded-md text-sm font-bold"
        >hi</span
      >
      <span class="brand-text">hibench</span>
    </a>
    <ul class="flex shrink-0 items-center gap-0.5 text-xs sm:gap-1 sm:text-sm">
      {
        links.map((l) => (
          <li>
            <a
              href={withBase(l.href)}
              class:list={[
                "rounded-md px-2 py-1.5 transition-colors sm:px-3",
                isActive(l.href) ? "nav-link-active font-semibold" : "nav-link",
              ]}
            >
              {l.label}
            </a>
          </li>
        ))
      }
      {
        (
          <li>
            <a
              href="https://github.com/hibenchmark/hibench"
              class="rounded-md px-2 py-1.5 transition-colors nav-link sm:px-3"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
        )
      }
    </ul>
  </nav>
</header>
