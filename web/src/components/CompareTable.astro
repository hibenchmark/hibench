---
import AgentLogo from './AgentLogo.astro';
import { withBase, formatNumber } from '../lib/format';
import type { AgentLogo as AgentLogoType } from '../data/benchmark';

type CompareAgent = {
  agentId: string;
  agentDisplayName: string;
  agentLogo: AgentLogoType;
  version: string;
  totalTokens: number;
  anthropicTotalTokens: number;
  toolCount: number;
  skillCount: number;
  subagentCount: number;
  href: string;
};

interface Props {
  agentA: CompareAgent;
  agentB: CompareAgent;
  hasAnthropicData: boolean;
  anthropicModel: string;
}

const { agentA, agentB, hasAnthropicData, anthropicModel } = Astro.props;

const tokensA = hasAnthropicData ? agentA.anthropicTotalTokens : agentA.totalTokens;
const tokensB = hasAnthropicData ? agentB.anthropicTotalTokens : agentB.totalTokens;
const heavier = tokensA >= tokensB ? 'a' : 'b';
const lighter = heavier === 'a' ? 'b' : 'a';
const heavierTokens = heavier === 'a' ? tokensA : tokensB;
const lighterTokens = lighter === 'a' ? tokensA : tokensB;
const tokenDelta = Math.abs(tokensA - tokensB);
const tokenRatio =
  lighterTokens > 0 ? heavierTokens / lighterTokens : 0;
const ratioLabel =
  tokenRatio >= 10 ? tokenRatio.toFixed(1) : tokenRatio.toFixed(2);

type MetricRow = {
  label: string;
  valueA: number;
  valueB: number;
  hint?: string;
};

const metrics: MetricRow[] = [
  {
    label: 'Default tokens',
    valueA: tokensA,
    valueB: tokensB,
    hint: hasAnthropicData
      ? `Anthropic ${anthropicModel} · latest request`
      : 'o200k_base · latest request',
  },
  { label: 'Tools', valueA: agentA.toolCount, valueB: agentB.toolCount },
  { label: 'Skills', valueA: agentA.skillCount, valueB: agentB.skillCount },
  {
    label: 'Sub-agents',
    valueA: agentA.subagentCount,
    valueB: agentB.subagentCount,
  },
];

const formatDelta = (a: number, b: number) => {
  const delta = a - b;
  if (delta === 0) return 'Even';
  const sign = delta > 0 ? '+' : '';
  return `${sign}${formatNumber(delta)}`;
};

const formatRatio = (a: number, b: number) => {
  if (a === b) return '1.00×';
  const high = Math.max(a, b);
  const low = Math.min(a, b);
  if (low <= 0) return '—';
  const ratio = high / low;
  return ratio >= 10 ? `${ratio.toFixed(1)}×` : `${ratio.toFixed(2)}×`;
};
---

<section class="ui-card overflow-hidden rounded-2xl">
  <div class="grid border-b border-[rgba(128,210,188,0.14)] md:grid-cols-2">
    {[agentA, agentB].map((agent, index) => (
      <a
        href={agent.href}
        class:list={[
          'group relative min-w-0 border-b border-[rgba(128,210,188,0.14)] p-5 transition hover:bg-[rgba(8,17,26,0.45)] md:border-b-0',
          index === 0 && 'md:border-r',
        ]}
      >
        <div class="flex min-w-0 items-center gap-3">
          <AgentLogo logo={agent.agentLogo} name={agent.agentDisplayName} size="md" />
          <div class="min-w-0">
            <p class="truncate text-lg font-semibold ui-title group-hover:text-[var(--color-primary)]">
              {agent.agentDisplayName}
            </p>
            <p class="mt-1 text-sm ui-muted">v{agent.version}</p>
          </div>
        </div>
        <p class="mt-3 text-xs font-medium uppercase tracking-[0.16em] ui-subtle">
          View agent profile
        </p>
      </a>
    ))}
  </div>

  <div class="border-b border-[rgba(128,210,188,0.14)] px-5 py-4">
    <div class="flex flex-wrap items-center justify-between gap-3">
      <p class="text-sm font-medium ui-muted">Token footprint summary</p>
      <p class="rounded-full border border-[rgba(128,210,188,0.2)] bg-[rgba(8,17,26,0.62)] px-2.5 py-1 text-xs font-medium ui-muted">
        {ratioLabel}× spread
      </p>
    </div>
    <p class="mt-2 text-sm ui-subtle">
      {heavier === 'a' ? agentA.agentDisplayName : agentB.agentDisplayName} loads{' '}
      <span class="font-semibold ui-title">{formatNumber(tokenDelta)}</span> more default tokens than{' '}
      {lighter === 'a' ? agentA.agentDisplayName : agentB.agentDisplayName}.
    </p>
  </div>

  <div class="divide-y divide-[rgba(128,210,188,0.12)]">
    {metrics.map((metric) => (
      <div class="grid gap-3 px-5 py-4 md:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,0.8fr)] md:items-center">
        <div>
          <p class="text-sm font-medium ui-muted">{metric.label}</p>
          {metric.hint && <p class="mt-1 text-xs ui-subtle">{metric.hint}</p>}
        </div>
        <p class="text-2xl font-semibold tabular-nums ui-title md:text-right">
          {formatNumber(metric.valueA)}
        </p>
        <p class="text-2xl font-semibold tabular-nums ui-title md:text-right">
          {formatNumber(metric.valueB)}
        </p>
        <div class="text-sm ui-subtle md:text-right">
          <p class="font-medium ui-muted">{formatDelta(metric.valueA, metric.valueB)}</p>
          <p class="mt-0.5">{formatRatio(metric.valueA, metric.valueB)}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="hidden border-t border-[rgba(128,210,188,0.14)] px-5 py-3 text-xs font-semibold uppercase tracking-[0.16em] ui-subtle md:grid md:grid-cols-[minmax(0,1.1fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,0.8fr)]">
    <span>Metric</span>
    <span class="text-right">{agentA.agentDisplayName}</span>
    <span class="text-right">{agentB.agentDisplayName}</span>
    <span class="text-right">Delta / ratio</span>
  </div>
</section>

<p class="mt-4 text-xs ui-subtle">
  Comparisons use each agent&apos;s latest captured hibench run.{' '}
  <a href={withBase('/methodology')} class="ui-link">See methodology</a> for capture details.
</p>