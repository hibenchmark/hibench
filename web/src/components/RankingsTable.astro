---
import { formatInputCost, formatNumber } from '../lib/format';

export interface RankRow {
  agentId: string;
  agentName: string;
  totalTokens: number;
  anthropicTotalTokens: number;
  toolCount: number;
  skillCount: number;
  mcpCount: number;
  subagentCount: number;
  logoSrc: string;
  logoAlt: string;
  logoSource: 'official' | 'generic';
  href: string;
}

type SortKey = 'totalTokens' | 'inputCost' | 'toolCount' | 'skillCount' | 'subagentCount' | 'agentName';

const { rows } = Astro.props as { rows: RankRow[] };

const columns: { key: SortKey; label: string; numeric: boolean; defaultDir: 'asc' | 'desc' }[] = [
  { key: 'agentName', label: 'Agent', numeric: false, defaultDir: 'asc' },
  { key: 'totalTokens', label: 'Token', numeric: true, defaultDir: 'desc' },
  { key: 'inputCost', label: 'Cost', numeric: true, defaultDir: 'desc' },
  { key: 'toolCount', label: 'Tools', numeric: true, defaultDir: 'desc' },
  { key: 'skillCount', label: 'Skills', numeric: true, defaultDir: 'desc' },
  { key: 'subagentCount', label: 'Sub-agents', numeric: true, defaultDir: 'desc' },
];
const compactLabels: Record<SortKey, string> = {
  agentName: 'Agent',
  totalTokens: 'Tok',
  inputCost: 'Cost',
  toolCount: 'Tools',
  skillCount: 'Skills',
  subagentCount: 'Sub',
};

const hasAnthropicData = rows.length > 0 && rows.every((r) => r.anthropicTotalTokens > 0);
const initialTokenValue = (row: RankRow) =>
  hasAnthropicData ? row.anthropicTotalTokens : row.totalTokens;
const sortedRows = [...rows].sort((a, b) => initialTokenValue(b) - initialTokenValue(a));
const maxO200k = Math.max(...sortedRows.map((r) => r.totalTokens), 1);
const maxAnthropic = Math.max(...sortedRows.map((r) => r.anthropicTotalTokens), 1);
const initialMax = hasAnthropicData ? maxAnthropic : maxO200k;
const initialSortKey: SortKey = 'totalTokens';
const initialSortDir = 'desc';

const dataSortAttrs = (row: RankRow) => ({
  'data-sort-agent-name': row.agentName.toLowerCase(),
  'data-sort-total-tokens': String(row.totalTokens),
  'data-o200k-total-tokens': String(row.totalTokens),
  'data-anthropic-total-tokens': String(row.anthropicTotalTokens),
  'data-sort-input-cost': String(row.totalTokens),
  'data-o200k-input-cost': String(row.totalTokens),
  'data-anthropic-input-cost': String(row.anthropicTotalTokens),
  'data-sort-tool-count': String(row.toolCount),
  'data-sort-skill-count': String(row.skillCount),
  'data-sort-subagent-count': String(row.subagentCount),
});
---

<div
  class="ui-card overflow-hidden rounded-xl"
  data-rankings-table
  data-sort-key={initialSortKey}
  data-sort-dir={initialSortDir}
>
  <div
    class="ui-table-scroll"
    role="region"
    aria-label="Default footprint ranking table"
    tabindex="0"
  >
    <table class="w-full table-fixed text-xs sm:min-w-[44rem] sm:text-sm">
      <colgroup>
        <col class="w-[4%] sm:w-[6%]" />
        <col class="w-[24%] sm:w-[28%]" />
        <col class="w-[19%] sm:w-[20%]" />
        <col class="w-[18%] sm:w-[16%]" />
        <col class="w-[11%] sm:w-[9%]" />
        <col class="w-[11%] sm:w-[9%]" />
        <col class="w-[13%] sm:w-[12%]" />
      </colgroup>
      <thead class="ui-table-head text-left">
        <tr>
          <th class="px-1 py-3 font-medium sm:px-4">#</th>
          {columns.map((column) => {
            const active = column.key === initialSortKey;
            const icon = active ? '▼' : '↕';
            const ariaSort = active ? 'descending' : 'none';
            const compactLabel = compactLabels[column.key];

            return (
              <th
                class={`px-1 py-3 font-medium sm:px-4 ${column.numeric ? 'text-right' : ''}`}
                aria-sort={ariaSort}
                data-sort-heading={column.key}
              >
                <button
                  type="button"
                  class={`inline-flex items-center gap-0.5 hover:text-[var(--color-primary)] sm:gap-1 ${
                    column.numeric ? 'justify-end' : ''
                  }`}
                  data-sort-key={column.key}
                  data-sort-numeric={String(column.numeric)}
                  data-sort-default-dir={column.defaultDir}
                  aria-pressed={active ? 'true' : 'false'}
                >
                  <span class="sm:hidden">{compactLabel}</span>
                  <span class="hidden sm:inline">{column.label}</span>
                  <span class="text-xs" aria-hidden="true" data-sort-icon={column.key}>{icon}</span>
                </button>
              </th>
            );
          })}
        </tr>
      </thead>
      <tbody class="divide-y divide-[var(--color-line)]" data-rankings-body>
        {sortedRows.map((row, index) => (
          <tr
            class="ui-table-row"
            data-rank-row
            {...dataSortAttrs(row)}
          >
            <td class="px-1 py-3 tabular-nums ui-subtle sm:px-4" data-rank-cell>{index + 1}</td>
            <td class="px-1 py-3 sm:px-4">
              <div class="flex items-center gap-1.5 sm:gap-3">
                <span
                  class={`agent-logo ${
                    row.logoSource === 'official' ? 'agent-logo-official' : 'agent-logo-generic'
                  } grid h-5 w-5 shrink-0 place-items-center overflow-hidden rounded-md p-0.5 sm:h-8 sm:w-8 sm:rounded-lg sm:p-1.5`}
                  title={row.logoAlt}
                >
                  <img
                    src={row.logoSrc}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="h-full w-full object-contain"
                  />
                </span>
                <div class="min-w-0">
                  <a href={row.href} class="block truncate font-medium leading-tight ui-link">
                    {row.agentName}
                  </a>
                </div>
              </div>
            </td>
            <td class="px-1 py-3 text-right sm:px-4">
              <div class="flex items-center justify-end gap-1 sm:gap-3">
                <div class="ui-track hidden h-2 w-28 overflow-hidden rounded-full sm:block">
                  <div
                    class="h-full rounded-full"
                    data-tokenizer-bar
                    data-o200k-width={String((row.totalTokens / maxO200k) * 100)}
                    data-anthropic-width={String((row.anthropicTotalTokens / maxAnthropic) * 100)}
                    style={`width: ${(initialTokenValue(row) / initialMax) * 100}%; background: linear-gradient(90deg, var(--color-primary), var(--color-secondary));`}
                  />
                </div>
                <span
                  class="tabular-nums font-semibold ui-title"
                  data-tokenizer-value
                  data-o200k-value={String(row.totalTokens)}
                  data-anthropic-value={String(row.anthropicTotalTokens)}
                >
                  {formatNumber(initialTokenValue(row))}
                </span>
              </div>
            </td>
            <td class="px-1 py-3 text-right tabular-nums sm:px-4">
              <span
                class="font-semibold ui-title"
                data-tokenizer-value
                data-tokenizer-format="input-cost"
                data-o200k-value={String(row.totalTokens)}
                data-anthropic-value={String(row.anthropicTotalTokens)}
              >
                {formatInputCost(initialTokenValue(row))}
              </span>
            </td>
            <td class="px-1 py-3 text-right tabular-nums sm:px-4">{row.toolCount}</td>
            <td class="px-1 py-3 text-right tabular-nums sm:px-4">{row.skillCount}</td>
            <td class="px-1 py-3 text-right tabular-nums sm:px-4">{row.subagentCount}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<script>
  const toDataName = (key: string) => key.replace(/[A-Z]/g, (char) => `-${char.toLowerCase()}`);

  for (const tableRoot of document.querySelectorAll('[data-rankings-table]')) {
    const body = tableRoot.querySelector('[data-rankings-body]');
    const buttons = Array.from(tableRoot.querySelectorAll('button[data-sort-key]'));

    if (!body || buttons.length === 0) continue;

    let sortKey = tableRoot.getAttribute('data-sort-key') || 'totalTokens';
    let sortDir = tableRoot.getAttribute('data-sort-dir') || 'desc';

    const activeTokenizer = () => (
      document.documentElement.dataset.tokenizer === 'anthropic' ? 'anthropic' : 'o200k'
    );

    const updateState = () => {
      for (const button of buttons) {
        const key = button.getAttribute('data-sort-key') || '';
        const active = key === sortKey;
        const icon = button.querySelector('[data-sort-icon]');
        const heading = button.closest('[data-sort-heading]');

        button.setAttribute('aria-pressed', active ? 'true' : 'false');
        if (icon) icon.textContent = active ? (sortDir === 'asc' ? '▲' : '▼') : '↕';
        if (heading) heading.setAttribute('aria-sort', active ? (sortDir === 'asc' ? 'ascending' : 'descending') : 'none');
      }
    };

    const updateTokenBars = () => {
      const tokenizer = activeTokenizer();
      tableRoot.querySelectorAll('[data-tokenizer-bar]').forEach((bar) => {
        if (!(bar instanceof HTMLElement)) return;
        const width = bar.dataset[`${tokenizer}Width`];
        if (width) bar.style.width = `${width}%`;
      });
    };

    const sortValue = (row: Element) => {
      if (sortKey === 'totalTokens' || sortKey === 'inputCost') {
        const tokenizer = activeTokenizer();
        const dataName = toDataName(sortKey);
        return row.getAttribute(`data-${tokenizer}-${dataName}`)
          || row.getAttribute(`data-sort-${dataName}`)
          || '';
      }

      const dataName = toDataName(sortKey);
      return row.getAttribute(`data-sort-${dataName}`) || '';
    };

    const compareRows = (a: Element, b: Element, numeric: boolean) => {
      const left = sortValue(a);
      const right = sortValue(b);
      const comparison = numeric
        ? Number(left) - Number(right)
        : left.localeCompare(right, undefined, { numeric: true, sensitivity: 'base' });

      return sortDir === 'asc' ? comparison : -comparison;
    };

    const renderRows = (numeric: boolean) => {
      const rows = Array.from(body.querySelectorAll('[data-rank-row]'));
      rows.sort((a, b) => compareRows(a, b, numeric));

      rows.forEach((row, index) => {
        const rankCell = row.querySelector('[data-rank-cell]');
        if (rankCell) rankCell.textContent = String(index + 1);
        body.append(row);
      });

      updateState();
      updateTokenBars();
    };

    const renderCurrentSort = () => {
      const activeButton = buttons.find((button) => button.getAttribute('data-sort-key') === sortKey);
      renderRows(activeButton?.getAttribute('data-sort-numeric') === 'true');
    };

    const sortRows = (nextKey: string, defaultDir: string, numeric: boolean) => {
      if (nextKey === sortKey) {
        sortDir = sortDir === 'asc' ? 'desc' : 'asc';
      } else {
        sortKey = nextKey;
        sortDir = defaultDir;
      }

      tableRoot.setAttribute('data-sort-key', sortKey);
      tableRoot.setAttribute('data-sort-dir', sortDir);

      renderRows(numeric);
    };

    for (const button of buttons) {
      button.addEventListener('click', () => {
        const nextKey = button.getAttribute('data-sort-key');
        if (!nextKey) return;

        sortRows(
          nextKey,
          button.getAttribute('data-sort-default-dir') || 'desc',
          button.getAttribute('data-sort-numeric') === 'true',
        );
      });
    }

    document.addEventListener('hibench:tokenizer-change', () => {
      renderCurrentSort();
    });

    renderCurrentSort();
  }
</script>