---
interface Props {
  hasAnthropicData: boolean;
  anthropicModel?: string;
  o200kModel?: string;
}

const { hasAnthropicData, anthropicModel = 'claude-opus-4-8', o200kModel = 'gpt-5.5' } = Astro.props;
---

<div class="flex flex-wrap items-center gap-2 text-sm" data-tokenizer-switch>
  <span class="font-medium ui-muted">Tokenizer</span>
  <div class="inline-flex rounded-full border border-white/10 bg-white/[0.03] p-1" role="group" aria-label="Token metric">
    <button
      type="button"
      class="rounded-full px-3 py-1 text-xs font-semibold transition"
      data-tokenizer-choice="o200k"
      aria-pressed={hasAnthropicData ? 'false' : 'true'}
    >
      <span class="block leading-tight">o200k_base</span>
      <span class="block text-[0.65rem] font-medium opacity-75">{o200kModel}</span>
    </button>
    <button
      type="button"
      class="rounded-full px-3 py-1 text-xs font-semibold transition disabled:cursor-not-allowed disabled:opacity-45"
      data-tokenizer-choice="anthropic"
      aria-pressed={hasAnthropicData ? 'true' : 'false'}
      disabled={!hasAnthropicData}
      title={hasAnthropicData ? `Anthropic ${anthropicModel}` : 'Run the Anthropic token backfill to enable this metric'}
    >
      <span class="block leading-tight">Anthropic</span>
      <span class="block text-[0.65rem] font-medium opacity-75">{anthropicModel}</span>
    </button>
  </div>
</div>

<style>
  :global([data-tokenizer-choice]) {
    color: var(--color-subtle);
  }

  :global([data-tokenizer-choice]:not([aria-pressed='true']):not(:disabled):hover) {
    background: rgba(154, 255, 234, 0.08);
    color: #d6fff1;
    box-shadow: inset 0 0 0 1px rgba(154, 255, 234, 0.18);
    cursor: pointer;
  }

  :global([data-tokenizer-choice]:not(:disabled):focus-visible) {
    outline: none;
    box-shadow: inset 0 0 0 1px rgba(154, 255, 234, 0.24), 0 0 0 2px rgba(49, 247, 195, 0.28);
  }

  :global([data-tokenizer-choice][aria-pressed='true']) {
    background: rgba(154, 255, 234, 0.14);
    color: #c8fff2;
    box-shadow: inset 0 0 0 1px rgba(154, 255, 234, 0.3), 0 8px 22px rgba(36, 214, 188, 0.12);
  }
</style>

<script is:inline>
  (() => {
    if (window.__hibenchTokenizerSwitch) return;
    window.__hibenchTokenizerSwitch = true;

    const storageKey = 'hibench.tokenizer';
    const numberFormat = new Intl.NumberFormat('en-US');
    const usdPreciseFormat = new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 4,
      maximumFractionDigits: 4,
    });
    const storedTokenizer = () => {
      try {
        return localStorage.getItem(storageKey);
      } catch {
        return null;
      }
    };
    const storeTokenizer = (tokenizer) => {
      try {
        localStorage.setItem(storageKey, tokenizer);
      } catch {
        /* ignore storage failures */
      }
    };

    const datasetValue = (el, tokenizer, suffix) => {
      const raw = el.dataset[`${tokenizer}${suffix}`];
      return raw === undefined || raw === '' ? undefined : raw;
    };

    const asNumber = (value) => {
      const n = Number(value);
      return Number.isFinite(n) ? n : 0;
    };

    const signedNumber = (value) => {
      const n = asNumber(value);
      return `${n >= 0 ? '+' : ''}${numberFormat.format(n)}`;
    };

    const inputCost = (value) => usdPreciseFormat.format((asNumber(value) * 5) / 1_000_000);

    const activeTokenizer = () => {
      const requested = storedTokenizer();
      const anthropicEnabled = Array.from(
        document.querySelectorAll('[data-tokenizer-choice="anthropic"]'),
      ).some((button) => !button.disabled);
      if (requested === 'o200k') return 'o200k';
      if (requested === 'anthropic') {
        return anthropicEnabled ? 'anthropic' : 'o200k';
      }
      return anthropicEnabled ? 'anthropic' : 'o200k';
    };

    const setActive = (tokenizer) => {
      if (tokenizer === 'anthropic') {
        storeTokenizer(tokenizer);
      } else {
        storeTokenizer('o200k');
      }
      updateTokenizerViews();
    };

    const updateTokenizerViews = () => {
      const tokenizer = activeTokenizer();
      document.documentElement.dataset.tokenizer = tokenizer;

      document.querySelectorAll('[data-tokenizer-choice]').forEach((button) => {
        const pressed = button.dataset.tokenizerChoice === tokenizer;
        button.setAttribute('aria-pressed', pressed ? 'true' : 'false');
      });

      document.querySelectorAll('[data-tokenizer-value]').forEach((el) => {
        const raw = datasetValue(el, tokenizer, 'Value');
        if (raw === undefined) return;
        const format = el.dataset.tokenizerFormat || 'number';
        if (format === 'signed') {
          el.textContent = signedNumber(raw);
        } else if (format === 'input-cost') {
          el.textContent = inputCost(raw);
        } else {
          el.textContent = numberFormat.format(asNumber(raw));
        }
      });

      document.querySelectorAll('[data-tokenizer-text]').forEach((el) => {
        const text = datasetValue(el, tokenizer, 'Text');
        if (text !== undefined) el.textContent = text;
      });

      document.querySelectorAll('[data-tokenizer-rank]').forEach((el) => {
        const rank = datasetValue(el, tokenizer, 'Rank');
        if (rank !== undefined) el.textContent = `Rank #${rank}`;
      });

      document.querySelectorAll('[data-tokenizer-panel]').forEach((el) => {
        el.hidden = el.dataset.tokenizerPanel !== tokenizer;
      });

      document.querySelectorAll('[data-tokenizer-sort-container]').forEach((container) => {
        const items = Array.from(container.querySelectorAll(':scope > [data-tokenizer-sort-item]'));
        items
          .sort((a, b) => {
            const bValue = asNumber(datasetValue(b, tokenizer, 'Sort'));
            const aValue = asNumber(datasetValue(a, tokenizer, 'Sort'));
            return bValue - aValue;
          })
          .forEach((item, index) => {
            item.style.order = String(index);
          });
      });

      document.dispatchEvent(
        new CustomEvent('hibench:tokenizer-change', { detail: { tokenizer } }),
      );
    };

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;
      const button = event.target.closest('[data-tokenizer-choice]');
      if (!button || button.disabled) return;
      setActive(button.dataset.tokenizerChoice);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', updateTokenizerViews, { once: true });
    } else {
      updateTokenizerViews();
    }
  })();
</script>