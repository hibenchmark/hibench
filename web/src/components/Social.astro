---
interface Props {
  platform: string;
  username: string;
  label?: string;
  class?: string;
}

const {
  platform,
  username,
  label = platform,
  class: className = "",
} = Astro.props;
const platformKey = platform.toLowerCase();
const href =
  platformKey === "github"
    ? `https://github.com/${username}`
    : platformKey === "x"
      ? `https://x.com/${username}`
    : `https://www.${platformKey}.com/${username}`;
---

<a
  class:list={["ui-link", "social-link", className]}
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={label}
  title={label}
>
  {
    platformKey === "github" ? (
      <svg
        aria-hidden="true"
        class="social-icon"
        viewBox="0 0 16 16"
        fill="currentColor"
        focusable="false"
      >
        <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82A7.65 7.65 0 0 1 8 3.86c.68 0 1.36.09 2 .26 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.06-1.87 3.75-3.65 3.95.29.25.55.74.55 1.49 0 1.07-.01 1.93-.01 2.2 0 .21.15.45.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
      </svg>
    ) : platformKey === "x" ? (
      <svg
        aria-hidden="true"
        class="social-icon"
        viewBox="0 0 128 128"
        fill="currentColor"
        focusable="false"
      >
        <path
          fill-rule="evenodd"
          clip-rule="evenodd"
          d="M86.8918 28.25H99.0219L72.5243 58.5334L103.698 99.75H79.285L60.1647 74.7536L38.2929 99.75H26.1627L54.5069 67.3565L24.5938 28.25H49.6199L66.9004 51.0974L86.8918 28.25ZM82.6337 92.4904H89.3555L45.9716 35.1301H38.7584L82.6337 92.4904Z"
        />
      </svg>
    ) : (
      label
    )
  }
</a>

<style>
  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    vertical-align: -0.125em;
  }

  .social-icon {
    height: 1.1rem;
    width: 1.1rem;
  }
</style>