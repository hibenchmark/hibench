---
import { formatNumber, pct, withBase } from "../lib/format";
import { canonicalTokenCount, type AgentSummary } from "../data/benchmark";
import AgentLogo from "./AgentLogo.astro";

interface Props {
  agents: AgentSummary[];
  limit?: number;
  topCount?: number;
  flopCount?: number;
}

const { agents, limit, topCount = 5, flopCount = 5 } = Astro.props;
const tokenValue = (agent: AgentSummary) => canonicalTokenCount(agent.latest);
const sorted = [...agents].sort((a, b) => tokenValue(b) - tokenValue(a));
const ranked = limit
  ? sorted.slice(0, limit)
  : [
      ...sorted.slice(0, topCount),
      ...sorted.slice(-flopCount),
    ].filter((agent, index, list) => (
      list.findIndex((candidate) => candidate.agentId === agent.agentId) === index
    ));
const rankByAgentId = new Map(sorted.map((agent, index) => [agent.agentId, index + 1]));
const max = Math.max(...ranked.map((a) => tokenValue(a)), 1);

type AgentTheme = {
  bar: string;
  badgeBg: string;
  badgeRing: string;
  badgeText: string;
  glow: string;
  labelText: string;
