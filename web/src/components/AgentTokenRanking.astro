const fallbackThemes: AgentTheme[] = [
  {
    bar: "linear-gradient(180deg, #f0abfc 0%, #d946ef 45%, #7c3aed 100%)",
    badgeBg: "rgba(217, 70, 239, 0.14)",
    badgeRing: "rgba(217, 70, 239, 0.34)",
    badgeText: "#f5d0fe",
