      "0 18px 42px rgba(217, 70, 239, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.4)",
  },
  {
    bar: "linear-gradient(180deg, #bef264 0%, #84cc16 45%, #15803d 100%)",
    badgeBg: "rgba(132, 204, 22, 0.14)",
    badgeRing: "rgba(132, 204, 22, 0.34)",
    badgeText: "#d9f99d",
    glow: "radial-gradient(circle, rgba(132, 204, 22, 0.4), transparent 68%)",
    labelText: "#bef264",
    shadow:
      "0 18px 42px rgba(132, 204, 22, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.4)",
  },
  {
    bar: "linear-gradient(180deg, #bfdbfe 0%, #60a5fa 45%, #4338ca 100%)",
    badgeBg: "rgba(96, 165, 250, 0.14)",
    badgeRing: "rgba(96, 165, 250, 0.34)",
    badgeText: "#bfdbfe",
    glow: "radial-gradient(circle, rgba(96, 165, 250, 0.42), transparent 68%)",
    labelText: "#93c5fd",
    shadow:
      "0 18px 42px rgba(96, 165, 250, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.4)",
  },
];

function themeFor(agentId: string): AgentTheme {
  if (agentThemes[agentId]) {
    return agentThemes[agentId];
  }

  let hash = 0;
  for (const char of agentId) {
    hash = (hash * 31 + char.charCodeAt(0)) % fallbackThemes.length;
  }
  return fallbackThemes[hash];
}
---

<div class="ui-card rounded-xl p-4 sm:p-6">
  <div class="flex items-start justify-between gap-3">
    <div>
      <p class="text-sm font-medium ui-muted">
        Top 5 and bottom 5 by default footprint
      </p>
      <p class="mt-1 text-xs ui-subtle">
        Largest and smallest latest versions · o200k_base total request tokens
      </p>
    </div>
    <a
      href={withBase("/rankings")}
      class="text-xs font-medium ui-link"
    >
      Full ranking →
    </a>
  </div>

  <div class="mt-4 overflow-hidden px-2 sm:px-0">
    <div
      class="flex min-h-56 w-full min-w-0 items-end gap-2 pb-0 sm:min-h-60 sm:gap-6"
    >
      {
        ranked.map((agent) => {
          const theme = themeFor(agent.agentId);
          const tokens = tokenValue(agent);
          const heightPct = pct(tokens, max);
          const labelFitsInside = heightPct >= 28;
          const outsideLabelBottom = `calc(${Math.max(heightPct, 7.5)}% + 0.6rem)`;
          const mobileLabelStyle = [
            "color:#f8fafc",
            "background:rgba(2,6,23,0.78)",
            "box-shadow:inset 0 0 0 1px rgba(226,232,240,0.56), 0 8px 18px rgba(0,0,0,0.38)",
            "text-shadow:0 1px 2px rgba(0,0,0,0.75)",
            "transform:translate(-50%, -50%) rotate(-90deg)",
          ].join(";");

          return (
            <a
              href={withBase(`/agents/${agent.agentId}`)}
              class="group flex min-w-0 flex-1 basis-0 flex-col items-center justify-end gap-2"
              aria-label={`${agent.agentDisplayName}: ${formatNumber(tokens)} o200k_base total request tokens`}
            >
              <span class="hidden w-full truncate text-center tabular-nums text-xs font-semibold ui-title sm:block sm:text-sm">
                {formatNumber(tokens)}
              </span>
              <div class="relative flex h-40 w-full max-w-[8rem] items-end justify-center overflow-hidden sm:h-44">
                {
                  !labelFitsInside && (
                    <span
                      aria-hidden="true"
                      class="absolute left-1/2 z-20 block whitespace-nowrap rounded-full px-1.5 py-0.5 tabular-nums text-[10px] font-bold leading-none tracking-tight sm:hidden"
                      style={`${mobileLabelStyle}; bottom:${outsideLabelBottom}`}
                    >
                      {formatNumber(tokens)}
                    </span>
                  )
                }
                <span
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-x-0 bottom-0 h-full overflow-hidden"
                >
                  <span
                    class="absolute bottom-0 left-1/2 h-20 w-20 -translate-x-1/2 rounded-full opacity-30 blur-2xl transition-opacity duration-300 group-hover:opacity-50 sm:h-28 sm:w-28"
                    style={`background:${theme.glow}`}
                  />
                </span>
                <div
                  class="relative w-full overflow-hidden rounded-t-2xl transition-transform duration-300 group-hover:-translate-y-1"
                  style={`height:${heightPct}%; min-height:0.75rem; background:${theme.bar}; box-shadow:${theme.shadow}`}
                >
                  <span
                    aria-hidden="true"
                    class="absolute inset-x-3 top-2 h-7 rounded-full bg-white/35 blur-md"
                  />
                  <span
                    aria-hidden="true"
                    class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-black/20 to-transparent"
                  />
                  {
                    labelFitsInside && (
                      <span
                        aria-hidden="true"
                        class="absolute left-1/2 top-1/2 z-10 block whitespace-nowrap rounded-full px-1.5 py-0.5 tabular-nums text-[10px] font-bold leading-none tracking-tight sm:hidden"
                        style={mobileLabelStyle}
                      >
                        {formatNumber(tokens)}
                      </span>
                    )
                  }
                </div>
              </div>
              <span class="flex max-w-full flex-col items-center text-center">
                <AgentLogo logo={agent.agentLogo} name={agent.agentDisplayName} size="sm" />
              </span>
            </a>
          );
        })
      }
    </div>
  </div>

  <div
    class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs ui-subtle"
  >
    {
      ranked.map((agent) => {
        const theme = themeFor(agent.agentId);
        const rank = rankByAgentId.get(agent.agentId) ?? 0;

        return (
          <span class="inline-flex items-center gap-1.5">
            <span
              class="grid h-4 w-4 place-items-center rounded-full text-[10px] font-semibold"
              style={`background:${theme.badgeBg}; color:${theme.badgeText}; box-shadow:inset 0 0 0 1px ${theme.badgeRing}`}
            >
              {rank}
            </span>
            <span>
              {agent.agentDisplayName}
            </span>
          </span>
        );
      })
    }
  </div>
</div>
