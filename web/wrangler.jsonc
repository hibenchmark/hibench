{
  "name": "hibench",
  "compatibility_date": "2026-06-16",
  "main": "./src/worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": true
  },
  "routes": [
    {
      "pattern": "hibench.dev",
      "custom_domain": true
    },
    {
      "pattern": "www.hibench.dev",
      "custom_domain": true
    }
  ]
}